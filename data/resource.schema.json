{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://learning-studio.local/schemas/resource.schema.json",
  "title": "Resource",
  "type": "object",
  "properties": {
    "id": { "type": "string" },
    "version": { "type": "string" },
    "title": { "type": "string" },
    "what_it_is": { "type": "string" },
    "why_use_it": { "type": "string" },
    "how_to": {
      "type": "array",
      "items": { "type": "string" }
    },
    "source_area": { "type": "string" },
    "last_reviewed": { "type": "string" },
    "review_status": { "type": "string", "enum": ["Draft", "Current", "Needs review", "Archived"] },
    "category": {
      "type": "string",
      "enum": [
        "Teams & Communication",
        "Assessment Tools",
        "Files & Permissions",
        "Accessibility & Assistive Technology",
        "Device & Windows Basics",
        "AI & Innovation"
      ]
    }
  },
  "required": [
    "id", "version", "title", "what_it_is", "why_use_it", "how_to", "source_area", "last_reviewed", "review_status", "category"
  ]
}
